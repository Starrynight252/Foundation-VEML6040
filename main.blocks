<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="1xX_Sv9EEF+7Q[o!rS9," x="0" y="0"><statement name="HANDLER"><block type="typescript_statement" id="=wG:j0#A8C,=6C:^,ty#"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace veml6040 {" line1="" line2="    // ===== I2C 地址 =====" line3="    const VEML6040_ADDR = 0x10" line4="" line5="    // ===== 寄存器地址 =====" line6="    const REG_CONF = 0x00" line7="    const REG_RED = 0x08" line8="    const REG_GREEN = 0x09" line9="    const REG_BLUE = 0x0A" line10="    const REG_WHITE = 0x0B" line11="" line12="    // ===== 积分时间（Integration Time）=====" line13="    //const IT_40MS = 0x00" line14="    // const IT_80MS = 0x10" line15="    // const IT_160MS = 0x20" line16="    const IT_320MS = 0x30" line17="    // const IT_640MS = 0x40" line18="    // const IT_1280MS = 0x50" line19="" line20="    // ===== 触发模式 =====" line21="    const TRIG_DISABLE = 0x00" line22="    //   const TRIG_ENABLE = 0x04" line23="" line24="    // ===== 自动 / 强制 =====" line25="    const AF_AUTO = 0x00" line26="    // const AF_FORCE = 0x02" line27="    const SD_ENABLE = 0x00" line28="    const SD_DISABLE = 0x01" line29="" line30="    // ===== Lux 灵敏度（Green 通道）=====" line31="    const GSENS_40MS = 0.25168" line32="    // const GSENS_80MS = 0.12584" line33="    // const GSENS_160MS = 0.06292" line34="    // const GSENS_320MS = 0.03146" line35="    // const GSENS_640MS = 0.01573" line36="    // const GSENS_1280MS = 0.007865" line37="" line38="    let initialized = false;" line39="    let redBuffer = 0;" line40="    let greenBuffer = 0;" line41="    let blueBuffer = 0;" line42="    let whiteBuffer = 0;" line43="" line44="    function setConfiguration() {" line45="        let buf = pins.createBuffer(3)" line46="        buf[0] = REG_CONF;" line47="        buf[1] = IT_320MS | AF_AUTO | SD_ENABLE;" line48="        buf[2] = 0;" line49="        pins.i2cWriteBuffer(VEML6040_ADDR, buf, false);" line50="    }" line51="" line52="    /**" line53="         * 初始化" line54="              */" line55="    //% block=&quot;init VEML6040&quot;" line56="    export function init(): void {" line57="" line58="        if (!initialized) {" line59="            setConfiguration();" line60="            // 等待时间" line61="            basic.pause(320);" line62="" line63="            initialized = true" line64="        }" line65="    }" line66="" line67="    /* 读取寄存器 */" line68="    function readReg(reg: number): number {" line69="        let regBuf = pins.createBuffer(1)" line70="        regBuf[0] = reg" line71="" line72="        pins.i2cWriteBuffer(VEML6040_ADDR, regBuf, false)" line73="        // pins.i2cWriteNumber(VEML6040_ADDR, reg, NumberFormat.UInt8BE, false)" line74="        let data = pins.i2cReadBuffer(VEML6040_ADDR, 2, false)" line75="" line76="        return data[0] | (data[1] &lt;&lt; 8)" line77="    }" line78="" line79="    /*读取全部颜色 */" line80="    //% block=&quot;read AllColour&quot;" line81="    export function readAllColour(): void {" line82="        init()  // 确保初始化一次" line83="" line84="        // 读取各通道" line85="        redBuffer = readReg(REG_RED)" line86="        basic.pause(320)" line87="        greenBuffer = readReg(REG_GREEN)" line88="        basic.pause(320)" line89="        blueBuffer = readReg(REG_BLUE)" line90="        basic.pause(320)" line91="        whiteBuffer = readReg(REG_WHITE)" line92="" line93="        //return [redBuffer, greenBuffer, blueBuffer, whiteBuffer]" line94="    }" line95="" line96="" line97="    // ====== RGB ======" line98="    //% block=&quot;read Red&quot;" line99="    export function readRed(): number {" line100="        init()" line101="        basic.pause(20);" line102="        return readReg(REG_RED)" line103="    }" line104="    //% block=&quot;read Green&quot;" line105="    export function readGreen(): number {" line106="        init()" line107="        basic.pause(20);" line108="        return readReg(REG_GREEN)" line109="    }" line110="    //% block=&quot;read Blue&quot;" line111="    export function readBlue(): number {" line112="        init()" line113="        basic.pause(20);" line114="        return readReg(REG_BLUE)" line115="    }" line116="    //% block=&quot;read White&quot;" line117="    export function readWhite(): number {" line118="        init()" line119="        basic.pause(20);" line120="        return readReg(REG_WHITE)" line121="    }" line122="    " line123="    // ====== CCT ======" line124="    //% block=&quot;read CCT&quot;" line125="    export function readCCT(): number {" line126="        let ccti = ((redBuffer - greenBuffer) / blueBuffer) + 0.5;" line127="        let cct = 4278.6 * Math.pow(ccti, -1.2455)" line128="" line129="        return Math.round(cct)" line130="    }" line131="}" numlines="132"></mutation></block></statement></block></xml>